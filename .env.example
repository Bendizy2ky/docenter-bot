# Copy this file, rename it to .env, and fill in your real keys
# NEVER share your .env file or push it to GitHub

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here


# Get this from your Paystack dashboard → Settings → API Keys
PAYSTACK_SECRET_KEY=your_paystack_secret_key_here

# Get this from https://www.remove.bg/api
REMOVEBG_API_KEY=your_removebg_api_key_here

# Get these from https://developer.ilovepdf.com
ILOVEPDF_PUBLIC_KEY=your_ilovepdf_public_key_here
ILOVEPDF_SECRET_KEY=your_ilovepdf_secret_key_here

# The public URL where your bot is hosted (for Paystack redirect)
# During development use: http://localhost:3000
APP_URL=http://localhost:3000

# The public URL of the FileForge web app domain
WEB_APP_URL=http://localhost:3000

# Admin configuration
ADMIN_TELEGRAM_ID=772990882
ADMIN_CREDITS=100

# AssemblyAI (preferred transcription provider)
ASSEMBLYAI_API_KEY=602e3589927542d3952ccc89bc6e8c45

# Optional proxy if your host cannot resolve AssemblyAI directly
# HTTPS_PROXY=http://proxy.example:3128
# HTTP_PROXY=http://proxy.example:3128

# Optional: maximum bytes to accept for transcription (default 15MB)
# TRANSCRIBE_MAX_BYTES=18874368
# Transcription poll timeout (ms)
# TRANSCRIBE_TIMEOUT_MS=180000